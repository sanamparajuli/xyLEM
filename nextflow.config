// ============================================================
// nextflow.config – Gene Family Identification Pipeline
// ============================================================

params {
    // ── Input files ──────────────────────────────────────────
    proteome        = "data/target_proteome.fasta"   // Query plant proteome
    genome          = "data/target_genome.fasta"     // Genome (optional, for gff extraction)
    hmm_profiles    = "data/profiles/*.hmm"          // One or more HMM profile files
    reference_db    = "data/reference_proteins.fasta"// Known gene family members (e.g. Arabidopsis)
    interpro_db     = "/path/to/interproscan/data"   // InterProScan database path

    // ── Domain filters ───────────────────────────────────────
    // InterPro/Pfam accessions expected in confirmed members
    // e.g. for WRKY: "PF03106", for MYB: "PF00249"
    target_domains  = "PF03106"   // Comma-separated list of Pfam/IPR accessions

    // ── Outgroup (optional) ─────────────────────────────────────
    // FASTA of outgroup sequence(s) to include in alignment + tree (null = skip)
    outgroup        = null

    // Sequence ID to root the IQ-TREE3 tree. Must match a FASTA header exactly.
    // For multiple outgroup taxa: "SeqA,SeqB"
    outgroup_taxon  = null

    // ── Output ───────────────────────────────────────────────
    outdir          = "results"

    // ── HMMER thresholds ─────────────────────────────────────
    hmmer_evalue    = 1e-5
    hmmer_coverage  = 0.5         // Min fraction of HMM length covered

    // ── BLAST thresholds ─────────────────────────────────────
    blast_evalue    = 1e-5
    blast_identity  = 30.0        // Min % identity for RBH
    blast_coverage  = 50.0        // Min query coverage %

    // ── IQ-TREE3 ─────────────────────────────────────────────
    iqtree_model    = "TEST"      // Auto model selection; or e.g. "LG+G4"
    iqtree_bootstrap= 1000        // UFBoot replicates

    // ── TrimAl ───────────────────────────────────────────────
    trimal_method   = "automated1" // or: "gappyout", "strict", "strictplus"

    // ── Resources ────────────────────────────────────────────
    threads         = 8
    max_memory      = "64.GB"
    max_cpus        = 32
    max_time        = "72.h"
}

// ── Process defaults ─────────────────────────────────────────
process {
    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139]
                        ? 'retry' : 'finish' }
    maxRetries    = 2

    withLabel: 'low_cpu' {
        cpus   = 2
        memory = '4.GB'
        time   = '1.h'
    }
    withLabel: 'medium_cpu' {
        cpus   = { params.threads }
        memory = '16.GB'
        time   = '6.h'
    }
    withLabel: 'high_cpu' {
        cpus   = { params.threads }
        memory = '32.GB'
        time   = '24.h'
    }
    withLabel: 'high_mem' {
        cpus   = { params.threads }
        memory = '64.GB'
        time   = '48.h'
    }

    // ── Tool-specific labels ──────────────────────────────────
    withName: 'HMMER_SEARCH'     { label = 'medium_cpu' }
    withName: 'INTERPROSCAN'     { label = 'high_cpu'   }
    withName: 'BLAST_FORWARD'    { label = 'medium_cpu' }
    withName: 'BLAST_REVERSE'    { label = 'medium_cpu' }
    withName: 'MUSCLE_ALIGN'     { label = 'medium_cpu' }
    withName: 'TRIMAL_TRIM'      { label = 'low_cpu'    }
    withName: 'IQTREE3'          { label = 'high_cpu'   }
}

// ── Profiles ─────────────────────────────────────────────────
profiles {

    // Local execution (default)
    local {
        process.executor = 'local'
    }

    // SLURM HPC cluster
    slurm {
        process.executor       = 'slurm'
        process.queue          = 'normal'
        process.clusterOptions = '--account=myaccount'
        executor {
            queueSize    = 50
            pollInterval = '30 sec'
        }
    }

    // LSF cluster
    lsf {
        process.executor = 'lsf'
        process.queue    = 'long'
    }

    // Conda environments
    conda {
        conda.enabled   = true
        conda.useMamba  = true   // set false if mamba unavailable
        process {
            withName: 'HMMER_SEARCH|FILTER_HMMER' {
                conda = 'bioconda::hmmer=3.4'
            }
            withName: 'INTERPROSCAN|CONFIRM_CANDIDATES' {
                conda = 'bioconda::interproscan=5.67-99.0'
            }
            withName: 'MAKEBLASTDB|BLAST_FORWARD|BLAST_REVERSE|RBH_FILTER' {
                conda = 'bioconda::blast=2.15.0'
            }
            withName: 'MUSCLE_ALIGN' {
                conda = 'bioconda::muscle=5.1'
            }
            withName: 'TRIMAL_TRIM' {
                conda = 'bioconda::trimal=1.4.1'
            }
            withName: 'IQTREE3' {
                conda = 'bioconda::iqtree=3.0.0'
            }
            withName: 'EXTRACT_SEQUENCES|SUMMARY_REPORT' {
                conda = 'conda-forge::python=3.11 bioconda::biopython=1.83'
            }
        }
    }

    // Docker containers
    docker {
        docker.enabled = true
        process {
            withName: 'HMMER_SEARCH|FILTER_HMMER' {
                container = 'biocontainers/hmmer:3.4--hdbdd923_1'
            }
            withName: 'INTERPROSCAN|CONFIRM_CANDIDATES' {
                container = 'biocontainers/interproscan:5.67-99.0--hec16e2b_0'
            }
            withName: 'MAKEBLASTDB|BLAST_FORWARD|BLAST_REVERSE|RBH_FILTER' {
                container = 'ncbi/blast:2.15.0'
            }
            withName: 'MUSCLE_ALIGN' {
                container = 'biocontainers/muscle:5.1--h9f5acd7_1'
            }
            withName: 'TRIMAL_TRIM' {
                container = 'biocontainers/trimal:1.4.1--h9f5acd7_6'
            }
            withName: 'IQTREE3' {
                container = 'biocontainers/iqtree:3.0.0--h21ec9f0_0'
            }
            withName: 'EXTRACT_SEQUENCES|SUMMARY_REPORT' {
                container = 'biocontainers/biopython:1.83'
            }
        }
    }

    // Singularity (HPC without Docker)
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        // Reuse docker containers via singularity pull
    }

    // Test profile (small dataset)
    test {
        params.proteome      = "test_data/test_proteome.fasta"
        params.hmm_profiles  = "test_data/test.hmm"
        params.reference_db  = "test_data/test_reference.fasta"
        params.target_domains = "PF03106"
        params.threads        = 2
        params.iqtree_bootstrap = 100
    }
}

// ── Reports & tracing ─────────────────────────────────────────
def timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

report {
    enabled = true
    file    = "${params.outdir}/pipeline_report_${timestamp}.html"
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_timeline_${timestamp}.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_trace_${timestamp}.txt"
    fields  = 'task_id,name,status,exit,duration,realtime,cpus,memory,rss,vmem'
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_dag_${timestamp}.svg"
}

manifest {
    name            = 'xyLEM Pipeline'
    author          = 'sanamparajuli'
    description     = 'Genome-wide identification of plant gene family members'
    version         = '1.0.0'
    nextflowVersion = '>=23.04'
    mainScript      = 'main.nf'
}
